# Cloudflare Pages 缓存策略(GH Pages 会忽略本文件)。
# CF Pages 默认给所有静态资源 max-age=14400, must-revalidate —— 对内容哈希
# 命名的 /_astro/* 来说这是白白浪费:文件名一变就是新 URL,内容永不改变,
# 所以可以安全地声明 immutable。

/_astro/*
  Cache-Control: public, max-age=31536000, immutable

# public/ 下的文件名不带哈希,只能给中等 TTL;换图后最长 30 天生效。
/favicon.ico
  Cache-Control: public, max-age=2592000

/apple-touch-icon.png
  Cache-Control: public, max-age=2592000

/og-default.png
  Cache-Control: public, max-age=2592000
