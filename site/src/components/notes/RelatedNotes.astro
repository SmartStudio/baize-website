---
/**
 * RelatedNotes — 笔记正文之后的「继续读」内链区。
 *
 * 存在的理由是内链,不是装饰:笔记之间原本几乎没有互链,抓取器进到任何一篇都是
 * 死胡同,读者读完也没有下一步。这里给每篇笔记 3 条出边(推荐逻辑见 lib/notes.ts)。
 *
 * 刻意不复用 NoteCard:那是带大封面的卡片,放在文末会盖过正文和 CTA。这里只要
 * 分类 + 标题 + 一句话,够读者判断要不要点进去即可。
 */
import type { CollectionEntry } from 'astro:content';

interface Props {
  notes: CollectionEntry<'notes'>[];
}

const { notes } = Astro.props;
const base = import.meta.env.BASE_URL;
---
{notes.length > 0 && (
  <nav class="bz-related" aria-label="相关笔记">
    <p class="bz-card__eyebrow">继续读</p>
    <ul class="bz-related__list">
      {notes.map((n) => (
        <li class="bz-related__item">
          <a class="bz-related__link" href={`${base}notes/${n.id}/`}>
            <span class="bz-related__cat">{n.data.category}</span>
            <span class="bz-related__title">{n.data.title}</span>
            <span class="bz-related__desc">{n.data.description}</span>
          </a>
        </li>
      ))}
    </ul>
  </nav>
)}

<style>
  .bz-related {
    margin-top: 56px;
    border-top: 1px solid var(--bz-border-subtle);
    padding-top: 32px;
  }

  .bz-related__list {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 20px;
    margin: 20px 0 0;
    padding: 0;
    list-style: none;
  }

  .bz-related__link {
    display: flex;
    flex-direction: column;
    gap: 6px;
    height: 100%;
    border-top: 2px solid var(--bz-border-strong);
    padding-top: 12px;
    color: inherit;
    text-decoration: none;
    transition: border-color var(--bz-transition-fast);
  }

  .bz-related__link:hover {
    border-top-color: var(--bz-accent);
  }

  .bz-related__link:focus-visible {
    outline: 3px solid var(--bz-focus-ring);
    outline-offset: 3px;
  }

  .bz-related__cat {
    color: var(--bz-text-muted);
    font-family: var(--bz-font-mono);
    font-size: var(--bz-type-caption-size);
    letter-spacing: 0.06em;
  }

  .bz-related__title {
    color: var(--bz-text-primary);
    font-family: var(--bz-font-display);
    font-size: 16px;
    font-weight: 650;
    line-height: 1.4;
    text-wrap: pretty;
  }

  .bz-related__link:hover .bz-related__title {
    color: var(--bz-accent-strong);
  }

  .bz-related__desc {
    color: var(--bz-text-muted);
    font-size: 14px;
    line-height: 1.6;
    /* 摘要只做「够不够点进去」的提示,不铺满三行把卡片撑歪 */
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
