---
interface Props {
  title: string;
  description: string;
  pubDate: Date;
  category: string;
  slug: string;
}
const { title, description, pubDate, category, slug } = Astro.props;
const base = import.meta.env.BASE_URL;
const href = `${base}notes/${slug}/`;
const dateStr = pubDate.toLocaleDateString('zh-CN', { year: 'numeric', month: '2-digit', day: '2-digit' });
---
<article class="bz-card" data-category={category}>
  <p class="bz-card__eyebrow">{category} · {dateStr}</p>
  <h3 class="bz-card__title"><a href={href}>{title}</a></h3>
  <p class="bz-card__body">{description}</p>
  <a class="bz-text-link" href={href}>阅读全文 <span class="bz-text-link__arrow">→</span></a>
</article>

<style>
  .bz-card__title a {
    color: inherit;
    text-decoration: none;
  }

  .bz-card__title a:hover {
    color: var(--bz-accent-strong);
  }
</style>
