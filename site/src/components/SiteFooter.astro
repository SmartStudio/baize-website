---
const base = import.meta.env.BASE_URL;
const year = new Date().getFullYear();
---
<footer class="bz-footer">
  <div class="bz-shell bz-footer__inner">
    <div class="bz-footer__brand">
      <span class="bz-topbar__wm bz-logotype">白泽明理</span>
      <p class="bz-eyebrow">Formal eXplainable AI</p>
    </div>
    <div class="bz-footer__contact">
      <a class="bz-text-link" href="mailto:fxai.labs@gmail.com">fxai.labs@gmail.com</a>
      <div class="bz-footer__qr">
        <img src={`${base}wechat-qr.jpg`} alt="白泽明理微信二维码" width="96" height="96" loading="lazy" />
        <span class="bz-eyebrow">微信扫码咨询</span>
      </div>
    </div>
    <a class="bz-button bz-button--primary" href={`${base}contact`}>预约 AI 落地诊断</a>
  </div>
  <p class="bz-footer__meta">© {year} 白泽明理 Baize Tech · Formal eXplainable AI</p>
</footer>
