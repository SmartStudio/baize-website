---
import { Image } from 'astro:assets';
import mark from '../assets/baize-mark.png';

const base = import.meta.env.BASE_URL; // 恒以 / 结尾
// 片段带尾斜杠:构建产物是 services/index.html,少一个斜杠 CF/GH Pages 就会 308。
// 首页用空片段,base 本身就是终态地址。
const NAV = [
  { href: '', label: '首页' },
  { href: 'services/', label: '服务' },
  { href: 'notes/', label: '明理笔记' },
  { href: 'method/', label: '方法论' },
  { href: 'about/', label: '关于白泽' },
  { href: 'contact/', label: '联系我们' },
];
---
<header class="bz-topbar">
  <a class="bz-topbar__brand" href={base}>
    {/* 34px 展示,单独出一档小图:SEO 流量直接落在笔记页,那里没有 hero 大图可复用。
        eager:它在每页首屏,Astro 默认的 lazy 反而会拖慢它(且首屏图懒加载会被 Lighthouse 扣分)。 */}
    <Image class="bz-topbar__logo" src={mark} alt="白泽明理" width={96} height={126} loading="eager" />
    <span class="bz-topbar__wm bz-logotype">白泽明理</span>
    <span class="bz-topbar__eyebrow">Formal eXplainable AI</span>
  </a>
  <button class="bz-topbar__toggle" aria-label="菜单" aria-expanded="false">≡</button>
  <nav class="bz-topbar__nav" aria-label="主导航">
    {NAV.map((n) => <a href={`${base}${n.href}`}>{n.label}</a>)}
    <a class="bz-topbar__cta bz-button bz-button--secondary bz-button--sm" href={`${base}contact/`}>预约咨询</a>
  </nav>
</header>
<script>
  const btn = document.querySelector('.bz-topbar__toggle');
  const nav = document.querySelector('.bz-topbar__nav');
  btn?.addEventListener('click', () => {
    const open = nav?.classList.toggle('is-open');
    btn.setAttribute('aria-expanded', String(!!open));
  });
</script>
