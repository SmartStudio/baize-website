---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  updatedDate?: Date;
  category: string;
  author: string;
  relatedService?: string;
  howto?: { name: string; steps: { name: string; text: string }[] };
  cover?: ImageMetadata;
  coverAlt?: string;
  path: string;
}

const { title, description, pubDate, updatedDate, category, author, relatedService, howto, cover, coverAlt, path } = Astro.props;
const base = import.meta.env.BASE_URL;

const dateStr = pubDate.toLocaleDateString('zh-CN', { year: 'numeric', month: '2-digit', day: '2-digit' });

const blogLd = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: title,
  description,
  datePublished: pubDate.toISOString(),
  ...(updatedDate ? { dateModified: updatedDate.toISOString() } : {}),
  author: { '@type': 'Organization', name: author },
  articleSection: category,
};

const howToLd = howto
  ? {
      '@context': 'https://schema.org',
      '@type': 'HowTo',
      name: howto.name,
      description,
      step: howto.steps.map((s, i) => ({
        '@type': 'HowToStep',
        position: i + 1,
        name: s.name,
        text: s.text,
      })),
    }
  : null;

const jsonLd = howToLd ? [blogLd, howToLd] : blogLd;

const SERVICE_CTA: Record<string, string> = {
  services: '五项工程服务总览',
  'dev-workflow': 'AI 研发流设计',
  'loop-engineering': 'Loop Engineering 设计',
  delivery: '想法到产品端到端交付设计',
  gateway: 'LLM API 网关设计',
};
const serviceLabel = (relatedService && SERVICE_CTA[relatedService]) || '五项工程服务';
---
<BaseLayout title={title} description={description} path={path} jsonLd={jsonLd}>
  <article class="bz-rail-section">
    <div class="bz-shell bz-note">
      <p class="bz-eyebrow">{category} · {dateStr}</p>
      <h1 class="bz-note__title">{title}</h1>
      <p class="bz-product-lead">{description}</p>

      {cover && (
        <figure class="bz-media bz-media--wide bz-note__cover">
          <Image src={cover} alt={coverAlt ?? title} class="bz-media__img" widths={[760, 1040, 1560]} sizes="(max-width: 800px) 100vw, 1040px" loading="eager" />
        </figure>
      )}

      <div class="bz-note__body">
        <slot />
      </div>

      <div class="bz-note__cta">
        <p class="bz-card__eyebrow">下一步</p>
        <h2 class="bz-note__cta-title">想把「{serviceLabel}」落到你的团队？</h2>
        <p class="bz-card__body">白泽明理提供设计、规范、蓝图与指导，不下场代做，帮你把这条路径走稳。</p>
        <div class="bz-note__cta-actions">
          <a class="bz-button bz-button--primary" href={`${base}contact`}>预约咨询</a>
          <a class="bz-text-link" href={`${base}services`}>查看服务详情 <span class="bz-text-link__arrow">→</span></a>
        </div>
      </div>
    </div>
  </article>

  <div id="bz-lightbox" class="bz-lightbox" role="dialog" aria-modal="true" aria-label="放大查看图片" hidden>
    <button type="button" class="bz-lightbox__close" aria-label="关闭">✕</button>
    <img class="bz-lightbox__img" src="" alt="" />
    <p class="bz-lightbox__cap" hidden></p>
  </div>
</BaseLayout>

<script>
  // 点击正文里带 data-zoomable 的图 → 放大到全屏 lightbox。渐进增强:无 JS 时图片照常显示。
  const overlay = document.getElementById('bz-lightbox');
  if (overlay) {
    const overlayImg = overlay.querySelector('.bz-lightbox__img') as HTMLImageElement;
    const overlayCap = overlay.querySelector('.bz-lightbox__cap') as HTMLElement;
    const closeBtn = overlay.querySelector('.bz-lightbox__close') as HTMLElement;
    let lastFocus: HTMLElement | null = null;

    const open = (img: HTMLImageElement) => {
      const cap = img.closest('figure')?.querySelector('.bz-figcap')?.textContent ?? '';
      overlayImg.src = img.currentSrc || img.src;
      overlayImg.alt = img.alt;
      overlayCap.textContent = cap;
      overlayCap.hidden = !cap;
      overlay.hidden = false;
      document.body.style.overflow = 'hidden';
      lastFocus = document.activeElement as HTMLElement;
      closeBtn.focus();
    };

    const close = () => {
      overlay.hidden = true;
      overlayImg.removeAttribute('src');
      document.body.style.overflow = '';
      lastFocus?.focus?.();
    };

    document.querySelectorAll<HTMLImageElement>('.bz-note__body [data-zoomable]').forEach((img) => {
      img.style.cursor = 'zoom-in';
      img.addEventListener('click', () => open(img));
    });

    overlay.addEventListener('click', (e) => {
      const t = e.target as HTMLElement;
      if (t === overlay || t.closest('.bz-lightbox__close')) close();
    });
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && !overlay.hidden) close();
    });
  }
</script>

<style>
  .bz-note {
    max-width: var(--bz-read-max);
  }

  .bz-note__title {
    margin: 20px 0 0;
    color: var(--bz-text-primary);
    font-family: var(--bz-font-display);
    font-size: clamp(30px, 4vw, 44px);
    font-weight: 600;
    line-height: 1.2;
    letter-spacing: -0.01em;
    text-wrap: balance;
  }

  .bz-note__body :global(p) {
    margin: 0 0 22px;
    color: var(--bz-text-secondary);
    font-size: 16px;
    line-height: 1.85;
  }

  .bz-note__body :global(h2) {
    margin: 44px 0 16px;
    color: var(--bz-text-primary);
    font-family: var(--bz-font-display);
    font-size: 24px;
    font-weight: 650;
    line-height: 1.35;
  }

  .bz-note__body :global(h3) {
    margin: 34px 0 14px;
    color: var(--bz-text-primary);
    font-size: 19px;
    font-weight: 650;
    line-height: 1.4;
  }

  .bz-note__body :global(ul),
  .bz-note__body :global(ol) {
    margin: 0 0 22px;
    padding-left: 22px;
    color: var(--bz-text-secondary);
    font-size: 16px;
    line-height: 1.85;
  }

  .bz-note__body :global(a) {
    color: var(--bz-accent-strong);
  }

  /* ---------- Cover hero ---------- */
  .bz-note__cover {
    margin-top: clamp(28px, 4vw, 44px);
    margin-bottom: 0;
  }

  /* ---------- Rich media: figures / video / galleries ----------
     Shared by the MDX components (Figure/Video/Figures) and the cover.
     Global on purpose: the cover figure lives outside .bz-note__body.
     wide/full break out symmetrically around the reading column, clamped
     to the page gutters so they never trigger horizontal overflow. */
  :global(.bz-media) {
    margin: clamp(28px, 4vw, 44px) 0;
  }

  :global(.bz-media__img),
  :global(.bz-media__video) {
    display: block;
    width: 100%;
    height: auto;
    background: var(--bz-paper-100);
  }

  :global(.bz-media--border .bz-media__img),
  :global(.bz-media--border .bz-media__video) {
    border: 1px solid var(--bz-border-subtle);
  }

  :global(.bz-media--content) {
    width: 100%;
  }

  :global(.bz-media--wide),
  :global(.bz-media--full) {
    position: relative;
    left: 50%;
    transform: translateX(-50%);
  }

  :global(.bz-media--wide) {
    width: min(1040px, calc(100vw - var(--bz-page-gutter) * 2));
  }

  :global(.bz-media--full) {
    width: min(var(--bz-page-max), calc(100vw - var(--bz-page-gutter) * 2));
  }

  /* bleed = 贴视口两边的满宽大图;图注收回阅读列宽居中,不跟着拉到 100vw */
  :global(.bz-media--bleed) {
    position: relative;
    left: 50%;
    transform: translateX(-50%);
    width: 100vw;
    max-width: 100vw;
  }

  :global(.bz-media--bleed .bz-figcap) {
    max-width: var(--bz-read-max);
    margin-left: auto;
    margin-right: auto;
    padding: 0 var(--bz-page-gutter);
  }

  :global(.bz-figcap) {
    margin: 12px 0 0;
    color: var(--bz-text-muted);
    font-size: var(--bz-type-caption-size);
    line-height: 1.55;
    text-align: center;
  }

  :global(.bz-figures) {
    display: grid;
    gap: clamp(10px, 1.6vw, 16px);
  }

  :global(.bz-figures--2) {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  :global(.bz-figures--3) {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  :global(.bz-figures .bz-media) {
    margin: 0;
  }

  :global(.bz-figures .bz-figcap) {
    text-align: left;
  }

  @media (max-width: 640px) {
    :global(.bz-figures--2),
    :global(.bz-figures--3) {
      grid-template-columns: minmax(0, 1fr);
    }
  }

  /* ---------- Callout ---------- */
  :global(.bz-callout) {
    margin: clamp(24px, 3.5vw, 36px) 0;
    border: 1px solid var(--bz-border-subtle);
    border-left: 3px solid var(--bz-border-strong);
    background: var(--bz-bg-alt);
    padding: 18px 20px;
  }

  :global(.bz-callout--tip) {
    border-left-color: var(--bz-accent);
  }

  :global(.bz-callout--warning) {
    border-left-color: var(--bz-orange-ink);
    background: var(--bz-orange-100);
  }

  :global(.bz-callout__title) {
    margin: 0 0 6px;
    color: var(--bz-text-primary);
    font-family: var(--bz-font-mono);
    font-size: var(--bz-type-caption-size);
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  /* Callout paragraphs inherit body-text styling; only trim outer margins.
     Scoped under .bz-note__body to out-specify the global :global(p) rule. */
  .bz-note__body :global(.bz-callout__body > :first-child) {
    margin-top: 0;
  }

  .bz-note__body :global(.bz-callout__body > :last-child) {
    margin-bottom: 0;
  }

  /* ---------- Code blocks (Shiki) + inline code + blockquote ---------- */
  .bz-note__body :global(pre) {
    margin: clamp(24px, 3.5vw, 32px) 0;
    padding: 18px 20px;
    border: 1px solid var(--bz-border-subtle);
    background: var(--bz-paper-100) !important;
    overflow-x: auto;
    font-size: 13.5px;
    line-height: 1.7;
  }

  .bz-note__body :global(pre code) {
    font-family: var(--bz-font-mono);
    font-size: inherit;
  }

  .bz-note__body :global(:not(pre) > code) {
    font-family: var(--bz-font-mono);
    font-size: 0.9em;
    background: var(--bz-paper-100);
    border: 1px solid var(--bz-border-subtle);
    padding: 1px 5px;
    color: var(--bz-ink-800);
  }

  .bz-note__body :global(blockquote) {
    margin: clamp(24px, 3.5vw, 32px) 0;
    padding-left: 20px;
    border-left: 3px solid var(--bz-accent);
    color: var(--bz-text-primary);
  }

  .bz-note__body :global(blockquote p) {
    color: var(--bz-text-primary);
  }

  /* ---------- Lightbox (click-to-zoom) ---------- */
  .bz-lightbox {
    position: fixed;
    inset: 0;
    z-index: 200;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 16px;
    padding: clamp(24px, 5vw, 64px);
    background: rgba(17, 24, 39, 0.92);
    cursor: zoom-out;
  }

  .bz-lightbox[hidden] {
    display: none;
  }

  .bz-lightbox__img {
    max-width: min(1200px, 92vw);
    max-height: 82vh;
    width: auto;
    height: auto;
    object-fit: contain;
    background: var(--bz-paper-100);
    cursor: default;
  }

  .bz-lightbox__cap {
    margin: 0;
    max-width: min(760px, 92vw);
    color: rgba(255, 255, 255, 0.82);
    font-size: var(--bz-type-caption-size);
    line-height: 1.55;
    text-align: center;
  }

  .bz-lightbox__close {
    position: absolute;
    top: clamp(12px, 2vw, 24px);
    right: clamp(12px, 2vw, 24px);
    width: 44px;
    height: 44px;
    display: flex;
    align-items: center;
    justify-content: center;
    border: 1px solid rgba(255, 255, 255, 0.3);
    background: transparent;
    color: #fff;
    font-size: 18px;
    line-height: 1;
    cursor: pointer;
  }

  .bz-lightbox__close:hover {
    border-color: #fff;
  }

  .bz-lightbox__close:focus-visible {
    outline: 3px solid var(--bz-focus-ring);
    outline-offset: 2px;
  }

  .bz-note__cta {
    margin-top: 56px;
    border-top: 1px solid var(--bz-border-subtle);
    padding-top: 40px;
  }

  .bz-note__cta-title {
    margin: 10px 0 0;
    color: var(--bz-text-primary);
    font-family: var(--bz-font-display);
    font-size: clamp(20px, 2.4vw, 28px);
    font-weight: 600;
    line-height: 1.35;
    text-wrap: balance;
  }

  .bz-note__cta-actions {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 16px;
    margin-top: 24px;
  }
</style>
