---
import BaseLayout from '../layouts/BaseLayout.astro';
import ContactForm from '../components/ContactForm.astro';
const base = import.meta.env.BASE_URL;
---
<BaseLayout
  title="联系我们"
  description="预约 AI 落地诊断，或就中转站、网关、Loop 与端到端交付路径咨询白泽明理。"
  path="/contact"
>
  <section class="bz-shell contact-page">
    <header class="contact-hero">
      <div class="bz-eyebrow">Contact</div>
      <h1 class="bz-home-heading">联系我们</h1>
      <p class="bz-home-lead">告诉我们团队现状和最想解决的问题，我们判断适合从哪里开始。白泽只做设计，不代开发、不代运维。</p>
    </header>
    <div class="contact-layout">
      <ContactForm />
      <aside class="bz-card contact-aside">
        <div class="bz-card__eyebrow">Direct</div>
        <h2 class="bz-card__title">直接联系我们</h2>
        <p class="bz-card__body">
          也可以直接发邮件，或加微信附上你的团队现状和最想解决的问题，我们会更快判断适合从哪里开始。
        </p>
        <a class="bz-text-link" href="mailto:fxai.labs@gmail.com">
          fxai.labs@gmail.com
          <span class="bz-text-link__arrow" aria-hidden="true">→</span>
        </a>
        <div class="contact-qr">
          <img
            src={`${base}wechat-qr.jpg`}
            alt="白泽明理微信二维码"
            width="160"
            height="160"
            loading="lazy"
          />
          <span class="bz-eyebrow">微信扫码咨询</span>
        </div>
      </aside>
    </div>
  </section>
</BaseLayout>

<style>
  .contact-page {
    padding: clamp(56px, 8vw, 96px) 0;
  }

  .contact-hero {
    margin-bottom: clamp(32px, 5vw, 56px);
  }

  .contact-hero .bz-home-lead {
    max-width: 62ch;
  }

  .contact-layout {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(260px, 340px);
    gap: clamp(32px, 5vw, 56px);
    align-items: start;
  }

  .contact-aside {
    gap: var(--bz-space-16);
  }

  .contact-qr {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 10px;
    margin-top: var(--bz-space-8);
  }

  .contact-qr img {
    width: 160px;
    height: 160px;
    object-fit: contain;
    border: var(--bz-border);
    border-radius: var(--bz-radius-8);
    background: var(--bz-paper-0);
    padding: 8px;
  }

  @media (max-width: 860px) {
    .contact-layout {
      grid-template-columns: 1fr;
    }
  }
</style>
