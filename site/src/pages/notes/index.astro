---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import NoteCard from '../../components/NoteCard.astro';
import { CATEGORIES, categorySlug } from '../../lib/notes';

const base = import.meta.env.BASE_URL;
const site = import.meta.env.SITE;

const notes = (await getCollection('notes', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

// 空分类不出归档页(见 category/[category].astro),所以筛选条也只列有笔记的分类——
// 免得点进去是个空页面。
const liveCategories = CATEGORIES.filter((c) => notes.some((n) => n.data.category === c));

const description =
  '白泽明理关于 AI 接入、工程与落地的笔记：接入安全、研发流程、Loop Engineering 与端到端交付。';

const blogLd = {
  '@context': 'https://schema.org',
  '@type': 'Blog',
  name: '明理笔记',
  description,
  url: new URL('/notes/', site).href,
  inLanguage: 'zh-CN',
  publisher: { '@type': 'Organization', name: '白泽明理 Baize Tech' },
  blogPost: notes.map((n) => ({
    '@type': 'BlogPosting',
    headline: n.data.title,
    description: n.data.description,
    url: new URL(`/notes/${n.id}/`, site).href,
    datePublished: n.data.pubDate.toISOString(),
    articleSection: n.data.category,
  })),
};

const breadcrumbLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: '首页', item: new URL('/', site).href },
    { '@type': 'ListItem', position: 2, name: '明理笔记' },
  ],
};
---
<BaseLayout
  title="明理笔记"
  description={description}
  path="/notes/"
  jsonLd={[blogLd, breadcrumbLd]}
>
  <section class="bz-rail-section">
    <div class="bz-shell">
      <header class="notes-head">
        <p class="bz-eyebrow">Baize Notes</p>
        <h1 class="bz-product-title">明理笔记</h1>
        <p class="bz-product-lead">关于 AI 接入、工程与落地的笔记，帮你把零散尝鲜变成可验证、可复用的组织能力。</p>
      </header>

      <div class="bz-section-header">
        <p class="bz-section-header__eyebrow">按话题筛选</p>
      </div>

      {/* 筛选项是真链接,不是纯 JS 按钮:
          - 抓取器顺着它发现分类归档页(否则归档页只有 sitemap 能找到,近乎孤儿);
          - 无 JS 时点击直接跳归档页,功能不丢;
          - 有 JS 时拦下来做即时筛选,并把地址栏同步成归档页地址——刷新会真的落到
            那一页,而内容与筛选结果一致,不会出现「URL 说 A、内容是 B」。 */}
      <nav class="bz-notes-filter" aria-label="按分类筛选笔记">
        <a class="bz-badge bz-badge--vermilion" href={`${base}notes/`} data-filter="all" aria-current="page">全部</a>
        {liveCategories.map((c) => (
          <a class="bz-badge bz-badge--neutral" href={`${base}notes/category/${categorySlug(c)}/`} data-filter={c}>{c}</a>
        ))}
      </nav>

      <div class="bz-notes-grid" id="notes-grid">
        {notes.map((note) => (
          <NoteCard
            title={note.data.title}
            description={note.data.description}
            pubDate={note.data.pubDate}
            category={note.data.category}
            slug={note.id}
            cover={note.data.cover}
            coverAlt={note.data.coverAlt}
          />
        ))}
      </div>

      <p class="bz-card__body" id="notes-empty" hidden>该分类暂时还没有笔记，欢迎先看看其他话题。</p>
    </div>
  </section>
</BaseLayout>

<style>
  .notes-head {
    margin-bottom: clamp(32px, 5vw, 56px);
  }

  .bz-notes-filter {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin: 24px 0 36px;
  }

  .bz-notes-filter a {
    border: none;
    cursor: pointer;
    text-decoration: none;
    transition: color var(--bz-transition-fast), background-color var(--bz-transition-fast);
  }

  .bz-notes-filter a:focus-visible {
    outline: 3px solid var(--bz-focus-ring);
    outline-offset: 2px;
  }

  .bz-notes-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 20px;
  }

  #notes-empty {
    margin-top: 32px;
  }
</style>

<script>
  // 渐进增强:链接本身已经能用(直接跳分类归档页),这里把它升级成不刷新的即时筛选。
  const links = Array.from(document.querySelectorAll<HTMLAnchorElement>('.bz-notes-filter a'));
  const cards = Array.from(document.querySelectorAll<HTMLElement>('#notes-grid [data-category]'));
  const empty = document.getElementById('notes-empty');

  links.forEach((link) => {
    link.addEventListener('click', (e) => {
      // 新标签页/中键打开等修饰键点击不拦截,让浏览器照常走真链接。
      if (e.metaKey || e.ctrlKey || e.shiftKey || e.altKey || (e as MouseEvent).button !== 0) return;
      e.preventDefault();

      const filter = link.dataset.filter || 'all';

      links.forEach((l) => {
        const active = l === link;
        l.toggleAttribute('aria-current', active);
        if (active) l.setAttribute('aria-current', 'page');
        l.classList.toggle('bz-badge--vermilion', active);
        l.classList.toggle('bz-badge--neutral', !active);
      });

      let visible = 0;
      cards.forEach((card) => {
        const match = filter === 'all' || card.dataset.category === filter;
        card.hidden = !match;
        if (match) visible += 1;
      });

      if (empty) empty.hidden = visible !== 0;

      // 地址栏同步到归档页地址:刷新/分享都会落到那一页,内容与当前筛选一致。
      history.replaceState(null, '', link.getAttribute('href'));
    });
  });
</script>
