---
/**
 * 分类归档页 /notes/category/<slug>/
 *
 * 归档页最容易变成「薄内容」——一堆标题列表、没有独立价值,反而稀释权重。两个防线:
 *   1. getStaticPaths 只为「有笔记的分类」出页。「AI普及」「安全可信」目前是 0 篇,
 *      不会产出空壳页;等哪天有笔记了,归档页自动出现,不用改代码。
 *   2. 每个分类有自己的导语(CATEGORY_INTROS),说清这一类在回答什么问题,而不是套模板。
 */
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import NoteCard from '../../../components/NoteCard.astro';
import { CATEGORIES, CATEGORY_INTROS, categorySlug } from '../../../lib/notes';

export async function getStaticPaths() {
  const notes = await getCollection('notes', ({ data }) => !data.draft);
  const liveCategories = CATEGORIES.filter((c) => notes.some((n) => n.data.category === c));

  return liveCategories.map((category) => ({
    params: { category: categorySlug(category) },
    props: {
      category,
      // 只把「同样有页面的分类」传下去做互链——链到空分类就是死链。
      siblings: liveCategories.filter((c) => c !== category),
      notes: notes
        .filter((n) => n.data.category === category)
        .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()),
    },
  }));
}

const { category, notes, siblings } = Astro.props;
const base = import.meta.env.BASE_URL;
const site = import.meta.env.SITE;

const intro = CATEGORY_INTROS[category];
const path = `/notes/category/${categorySlug(category)}/`;
const canonical = new URL(path, site).href;
const description = `明理笔记 · ${category}：${intro}`;

const collectionLd = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: `${category} · 明理笔记`,
  description,
  url: canonical,
  inLanguage: 'zh-CN',
  isPartOf: { '@type': 'Blog', name: '明理笔记', url: new URL('/notes/', site).href },
  mainEntity: {
    '@type': 'ItemList',
    numberOfItems: notes.length,
    itemListElement: notes.map((n, i) => ({
      '@type': 'ListItem',
      position: i + 1,
      url: new URL(`/notes/${n.id}/`, site).href,
      name: n.data.title,
    })),
  },
};

const breadcrumbLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: '首页', item: new URL('/', site).href },
    { '@type': 'ListItem', position: 2, name: '明理笔记', item: new URL('/notes/', site).href },
    { '@type': 'ListItem', position: 3, name: category },
  ],
};
---
<BaseLayout
  title={`${category} · 明理笔记`}
  description={description}
  path={path}
  jsonLd={[collectionLd, breadcrumbLd]}
>
  <section class="bz-rail-section">
    <div class="bz-shell">
      <header class="cat-head">
        <p class="bz-eyebrow"><a class="cat-back" href={`${base}notes/`}>明理笔记</a> · {category}</p>
        <h1 class="bz-product-title">{category}</h1>
        <p class="bz-product-lead">{intro}</p>
        <p class="cat-count">共 {notes.length} 篇</p>
      </header>

      <div class="bz-notes-grid">
        {notes.map((note) => (
          <NoteCard
            title={note.data.title}
            description={note.data.description}
            pubDate={note.data.pubDate}
            category={note.data.category}
            slug={note.id}
            cover={note.data.cover}
            coverAlt={note.data.coverAlt}
          />
        ))}
      </div>

      <nav class="cat-more" aria-label="其他分类">
        <p class="bz-card__eyebrow">换个话题</p>
        <div class="cat-more__links">
          <a class="bz-badge bz-badge--neutral" href={`${base}notes/`}>全部笔记</a>
          {siblings.map((c) => (
            <a class="bz-badge bz-badge--neutral" href={`${base}notes/category/${categorySlug(c)}/`}>{c}</a>
          ))}
        </div>
      </nav>
    </div>
  </section>
</BaseLayout>

<style>
  .cat-head {
    margin-bottom: clamp(32px, 5vw, 56px);
  }

  .cat-back {
    color: inherit;
  }

  .cat-count {
    margin: 16px 0 0;
    color: var(--bz-text-muted);
    font-family: var(--bz-font-mono);
    font-size: var(--bz-type-caption-size);
  }

  .bz-notes-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 20px;
  }

  .cat-more {
    margin-top: 56px;
    border-top: 1px solid var(--bz-border-subtle);
    padding-top: 32px;
  }

  .cat-more__links {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-top: 16px;
  }

  .cat-more__links a {
    text-decoration: none;
  }
</style>
