---
import BaseLayout from '../layouts/BaseLayout.astro';

const base = import.meta.env.BASE_URL;

const scenes = [
  {
    n: '01',
    t: 'AI 编程团队训练',
    b: '把研发团队从各自尝鲜的用法，训练成一套统一的 AI 编程工作流，明确规范、评审与验收标准。',
    out: '对应服务 · AI 编程培训 · AI 研发流设计',
  },
  {
    n: '02',
    t: '小团队研发流程改造',
    b: '人少的团队从最小可验证的 AI 工作流起步，先跑通一条回路，再逐步扩展到完整研发流程。',
    out: '对应服务 · AI 研发流设计 · Loop Engineering 设计',
  },
  {
    n: '03',
    t: '中转站 / LLM 网关搭建',
    b: '为团队搭建统一、可控、可审计的 AI 使用入口，鉴权、路由、限流与成本在一处管好。',
    out: '对应服务 · Codex 中转站搭建 · LLM API 网关设计',
  },
  {
    n: '04',
    t: 'Loop 与 Skills 沉淀',
    b: '把已经跑通的有效回路，固化成团队可复用的 Skills、SOP 与知识资产，而不是留在个人经验里。',
    out: '对应服务 · Loop Engineering 设计 · 端到端交付设计',
  },
];
---
<BaseLayout
  title="场景案例"
  description="第一版以示意场景呈现白泽能解决的问题类型，不虚构客户。涵盖训练、研发流改造、网关搭建与 Loop 沉淀。"
  path="/cases"
>
  <section class="bz-product-hero">
    <div class="bz-product-hero__grid">
      <div class="bz-product-hero__copy">
        <div class="bz-eyebrow">Cases</div>
        <h1 class="bz-product-title">用示意场景，看白泽能解决的问题类型。</h1>
        <p class="bz-product-lead">
          第一版案例页尚未积累可公开的真实客户案例，下面用「示意场景」呈现白泽通常介入的问题类型，不代表具体客户，也不构成具体承诺。
        </p>
      </div>
    </div>
  </section>

  <section class="bz-rail-section bz-rail-section--alt">
    <div class="bz-rail-grid">
      <aside>
        <div class="bz-rail-label">Scenarios</div>
        <div class="bz-rail-bar"></div>
      </aside>
      <div class="bz-home-intro">
        <div>
          <h2 class="bz-home-heading">四类示意场景。</h2>
          <p class="bz-home-lead">每张卡片都标注「示意场景」，用于说明白泽通常介入的问题类型，不是真实客户案例。</p>
        </div>
        <div class="bz-cell-grid bz-cell-grid--4" aria-label="场景案例">
          {scenes.map((s) => (
            <article class="bz-cell">
              <div class="bz-cell__n">{s.n}</div>
              <span class="bz-badge bz-badge--neutral">示意场景</span>
              <h3 class="bz-cell__t">{s.t}</h3>
              <p class="bz-cell__b">{s.b}</p>
              <div class="bz-cell__out">{s.out}</div>
            </article>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="bz-rail-section">
    <div class="bz-shell">
      <div class="bz-home-contact">
        <div>
          <h2 class="bz-home-contact__title">想看这类问题怎么落地，先约一次咨询。</h2>
          <p class="bz-home-contact__body">
            如果你的团队正卡在类似场景，白泽可以先做一次 AI 落地诊断，给出针对你团队的问题拆解与优先级。
          </p>
        </div>
        <a class="bz-button bz-button--primary bz-button--lg" href={`${base}contact`}>预约 AI 落地诊断</a>
      </div>
    </div>
  </section>
</BaseLayout>
