# 联系表单 → 飞书多维表格 所需的环境变量（本地联调用 .dev.vars，生产在 CF Pages 环境变量里配）。
# 复制本文件为 .dev.vars 并填入真实值（.dev.vars 已 gitignore，不会提交）。
#
# 上线前置（缺一不可）：
#  1. 飞书开放平台创建「自建应用」，拿到 app_id（cli_ 开头）与 app_secret。
#  2. 开通权限：bitable:app、base:record:create。
#  3. 打开目标多维表格 → 右上角「分享」→ 把应用加为「可编辑」协作者（否则写入报 91403）。
#  4. 表头必须是：姓名 / 公司 / 联系方式 / 感兴趣的服务 / 当前最想解决的问题（与 functions/api/_feishu.ts 的 mapFields 一致）。

FEISHU_APP_ID=cli_xxxxxxxxxxxx
FEISHU_APP_SECRET=你的AppSecret
# app_token = 多维表格 URL 里 base/ 后面那段；table_id = URL 里 ?table= 后面那段
BITABLE_APP_TOKEN=你的多维表格_app_token
BITABLE_TABLE_ID=tbl你的table_id
# GitHub Pages 镜像站的 origin（供跨源表单提交时 CORS 放行）；CF 主站同源可留空
ALLOWED_ORIGIN=https://<user>.github.io
